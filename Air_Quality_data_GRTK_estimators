.read_airquality_xlsx <- function(path) {
  if (requireNamespace("readxl", quietly = TRUE)) {
    df <- as.data.frame(readxl::read_excel(path))
    return(df)
  }
  if (requireNamespace("openxlsx", quietly = TRUE)) {
    df <- openxlsx::read.xlsx(path)
    return(df)
  }
  stop("Install either 'readxl' or 'openxlsx' to read the .xlsx file.")
}

.clean_airquality <- function(df) {
  # Replace -200 with NA in numeric columns
  for (nm in names(df)) {
    if (is.numeric(df[[nm]])) {
      df[[nm]][df[[nm]] <= -199.999] <- NA
    }
  }

  # Build datetime if Date + Time exist
  if (all(c("Date", "Time") %in% names(df))) {
    dt_char <- paste(df$Date, df$Time)
    dt <- suppressWarnings(as.POSIXct(dt_char, format = "%d/%m/%Y %H:%M:%S", tz = "UTC"))
    if (all(is.na(dt))) {
      dt <- suppressWarnings(as.POSIXct(dt_char, format = "%m/%d/%Y %H:%M:%S", tz = "UTC"))
    }
    df$datetime <- dt
  } else {
    df$datetime <- NA
  }

  # Hour-of-day
  if (!all(is.na(df$datetime))) {
    hh <- as.numeric(format(df$datetime, "%H"))
    mm <- as.numeric(format(df$datetime, "%M"))
    df$hour <- hh + mm/60
  } else {
    df$hour <- NA_real_
  }

  df$time_index <- seq_len(nrow(df))
  df
}

# --------------------------- Nonlinearity screening ---------------------------

.pick_z_by_nonlinearity <- function(y, cand_list) {
  best_name <- NULL
  best_gain <- -Inf

  for (nm in names(cand_list)) {
    z <- cand_list[[nm]]
    ok <- is.finite(y) & is.finite(z)
    if (sum(ok) < 80) next

    yy <- y[ok]; zz <- z[ok]

    fit_lm <- lm(yy ~ zz)
    sse_lm <- sum(residuals(fit_lm)^2)

    fit_sp <- smooth.spline(zz, yy)
    pred_sp <- predict(fit_sp, zz)$y
    sse_sp <- sum((yy - pred_sp)^2)

    sst <- sum((yy - mean(yy))^2)
    r2_lm <- 1 - sse_lm/sst
    r2_sp <- 1 - sse_sp/sst
    gain <- r2_sp - r2_lm

    if (is.finite(gain) && gain > best_gain) {
      best_gain <- gain
      best_name <- nm
    }
  }

  list(best_name = best_name, best_gain = best_gain)
}

# -------------------------- Diagnostics plots --------------------------------

.plot_corr_heatmap <- function(X, main = "Correlation among X covariates") {
  C <- suppressWarnings(cor(X, use = "pairwise.complete.obs"))
  C[!is.finite(C)] <- 0

  image(1:ncol(C), 1:ncol(C), t(C[ncol(C):1, ]), axes = FALSE,
        xlab = "", ylab = "", main = main)
  axis(1, at = 1:ncol(C), labels = colnames(C), las = 2, cex.axis = 0.8)
  axis(2, at = 1:ncol(C), labels = rev(colnames(C)), las = 2, cex.axis = 0.8)
  box()

  for (i in 1:ncol(C)) {
    for (j in 1:ncol(C)) {
      text(i, ncol(C) - j + 1, sprintf("%.2f", C[j, i]), cex = 0.7)
    }
  }
}

.plot_eigen_diagnostic <- function(X, main = "Eigenvalues of corr(X)") {
  C <- suppressWarnings(cor(X, use = "pairwise.complete.obs"))
  C[!is.finite(C)] <- 0
  ev <- eigen(C, symmetric = TRUE, only.values = TRUE)$values
  ev <- sort(ev, decreasing = TRUE)
  plot(ev, type = "b", pch = 16, xlab = "Index", ylab = "Eigenvalue",
       main = main)
  abline(h = 0, lty = 3, col = "gray50")
}

make_informative_figure <- function(df, y, X, z, z_name) {
  out_png <- file.path(OUT_DIR, "Fig_AirQuality_InformativePlots.png")

  png(out_png, width = 1600, height = 1100, res = 140)
  par(mfrow = c(3, 2), mar = c(4, 4, 3, 1))

  # (a) time series
  if ("datetime" %in% names(df) && !all(is.na(df$datetime))) {
    plot(df$datetime, y, type = "l", xlab = "Time", ylab = RESPONSE_COL,
         main = "(a) Response time series")
  } else {
    plot(y, type = "l", xlab = "Index", ylab = RESPONSE_COL,
         main = "(a) Response time series (index)")
  }

  # (b) y vs z
  plot(z, y, pch = 16, cex = 0.5, xlab = z_name, ylab = RESPONSE_COL,
       main = paste0("(b) Response vs z (", z_name, ")"))
  ss <- smooth.spline(z, y)
  lines(ss$x, ss$y, lwd = 2)

  # (c) corr heatmap
  .plot_corr_heatmap(X, main = "(c) Correlation among selected X")

  # (d) eigenvalues
  .plot_eigen_diagnostic(X, main = "(d) Eigenvalues of corr(X)")

  # (e) ACF of y
  acf(y, main = "(e) ACF of response", lag.max = 48)

  # (f) histogram
  hist(y, breaks = 30, main = "(f) Distribution of response", xlab = RESPONSE_COL)

  dev.off()

  cat("Saved:", out_png, "\n")
}


