      R_mode = "I",
      make_plots = TRUE, make_contours = TRUE,
      save_outputs = TRUE,
      out_dir = OUT_DIR,
      prefix = paste0("AirQuality_", estimator, "_tuning")
    )
    return(sel)
  }
  if (estimator == "RTK") {
    sel <- Selection_bw_k(
      x = X, z = z01, y = y,
      bw_seq = BW_SEQ, k_seq = K_SEQ,
      lag = 1,
      criteria = CRITERIA,
      R_mode = "I",
      make_plots = TRUE, make_contours = TRUE,
      save_outputs = TRUE,
      out_dir = OUT_DIR,
      prefix = paste0("AirQuality_", estimator, "_tuning")
    )
    return(sel)
  }
  if (estimator == "GRTK") {
    sel <- Selection_bw_k(
      x = X, z = z01, y = y,
      bw_seq = BW_SEQ, k_seq = K_SEQ,
      lag = 1,
      criteria = CRITERIA,
      R_mode = "AR1",
      make_plots = TRUE, make_contours = TRUE,
      save_outputs = TRUE,
      out_dir = OUT_DIR,
      prefix = paste0("AirQuality_", estimator, "_tuning")
    )
    return(sel)
  }
}

