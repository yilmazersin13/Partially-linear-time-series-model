# ---------------------------- Coefficient table -------------------------------

# Var(beta_hat) ≈ sigma^2 (A^{-1} (XtRinvXt) A^{-1})
# where A = XtRinvXt + k I.
.compute_beta_se <- function(fit, Rinv, k) {
  xtil <- fit$xtil
  XtRinvXt <- crossprod(xtil, Rinv %*% xtil)
  p <- ncol(xtil)
  A <- XtRinvXt + k * diag(p)

  # df approximation
  df <- df_fast(fit$W, fit$Iw, xtil, A, Rinv)
  df_res <- max(5, nrow(xtil) - df)

  res <- y - fit$yhat
  sigma2 <- sum(res^2) / df_res

  V <- sigma2 * solve(A, XtRinvXt) %*% solve(A)
  se <- sqrt(pmax(0, diag(V)))
  list(se = se, sigma2 = sigma2, df = df, df_res = df_res)
}

