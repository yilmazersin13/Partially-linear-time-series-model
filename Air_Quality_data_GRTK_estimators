if (DO_ROLLING_CV) {
  cat("Running rolling-origin evaluation...\n")

  N <- length(y)
  n_train0 <- floor(TRAIN_FRAC * N)

  # rolling windows: expanding training set, fixed test block of size ROLL_STEP
  starts <- seq(n_train0, min(N - ROLL_STEP, n_train0 + (N_ROLLS_MAX-1)*ROLL_STEP), by = ROLL_STEP)

  rmse <- function(a, b) sqrt(mean((a - b)^2))

  roll_rows <- list()
  rr <- 1L

  for (s in starts) {
    idx_tr <- 1:s
    idx_te <- (s+1):(s+ROLL_STEP)

    y_tr <- y[idx_tr]; X_tr <- X[idx_tr, , drop = FALSE]; z_tr <- z01[idx_tr]
    y_te <- y[idx_te]; X_te <- X[idx_te, , drop = FALSE]; z_te <- z01[idx_te]

    # For speed & compactness, keep tuning fixed to full-sample MAIN_CRIT pairs.
    # (If you want re-tuning per roll, we can do it, but it becomes heavy.)
    ntr <- length(y_tr)

    # KS / RTK (independence)
    fitKS_tr  <- fit_plm_once(X_tr, z_tr, y_tr, bw = pair_KS$bw, k = 0, Rinv = diag(ntr))
    fitRTK_tr <- fit_plm_once(X_tr, z_tr, y_tr, bw = pair_RTK$bw, k = pair_RTK$k, Rinv = diag(ntr))

    # GRTK: estimate rho on training residuals using a pilot fit (working I)
    pilot_tr <- fit_plm_once(X_tr, z_tr, y_tr, bw = median(BW_SEQ), k = median(K_SEQ[K_SEQ>0]), Rinv = diag(ntr))
    rho_tr <- estimate_rho_ar1(y_tr - pilot_tr$yhat, lag = 1)
    Rtr <- AR1_corr_matrix(ntr, rho_tr)
    Rtr_inv <- safe_chol_inv(Rtr)
    fitGRTK_tr <- fit_plm_once(X_tr, z_tr, y_tr, bw = pair_GRTK$bw, k = pair_GRTK$k, Rinv = Rtr_inv)

    gaussian_kernel <- function(u) exp(-0.5 * u^2)
    W_te_tr <- function(z_te, z_tr, bw) {
      D <- outer(z_te, z_tr, "-") / bw
      K <- gaussian_kernel(D)
      rs <- rowSums(K) + 1e-12
      K / rs
    }

    pred_from_fit <- function(beta_hat, y_tr, X_tr, z_tr, X_te, z_te, bw) {
      W <- W_te_tr(z_te, z_tr, bw)
      yhat_te <- as.vector(W %*% y_tr + (X_te - W %*% X_tr) %*% beta_hat)
      yhat_te
    }

    yhat_KS  <- pred_from_fit(fitKS_tr$beta_hat,  y_tr, X_tr, z_tr, X_te, z_te, pair_KS$bw)
    yhat_RTK <- pred_from_fit(fitRTK_tr$beta_hat, y_tr, X_tr, z_tr, X_te, z_te, pair_RTK$bw)
    yhat_GRTK<- pred_from_fit(fitGRTK_tr$beta_hat,y_tr, X_tr, z_tr, X_te, z_te, pair_GRTK$bw)

    roll_rows[[rr]] <- data.frame(
      roll_id = rr,
      train_end = s,
      test_start = s+1,
      test_end = s+ROLL_STEP,
      RMSE_KS = rmse(y_te, yhat_KS),
      RMSE_RTK = rmse(y_te, yhat_RTK),
      RMSE_GRTK = rmse(y_te, yhat_GRTK),
      rho_hat_train = rho_tr
    )
    rr <- rr + 1L
  }

  roll_df <- do.call(rbind, roll_rows)
  write.csv(roll_df, file.path(OUT_DIR, "Table_realdata_rollingCV_RMSE.csv"), row.names = FALSE)

  roll_mean <- data.frame(
    RMSE_KS_mean = mean(roll_df$RMSE_KS),
    RMSE_RTK_mean = mean(roll_df$RMSE_RTK),
    RMSE_GRTK_mean = mean(roll_df$RMSE_GRTK)
  )
  write.csv(roll_mean, file.path(OUT_DIR, "Table_realdata_rollingCV_RMSE_mean.csv"), row.names = FALSE)

  cat("Saved rolling CV tables.\n")
}

